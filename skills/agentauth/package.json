{
  "name": "agentauth-cli",
  "version": "0.1.0",
  "description": "CLI for running approval flows with LoginID Identity Gateway and OpenClaw",
  "type": "commonjs",
  "bin": {
    "agentauth": "./src/index.mjs"
  },
  "scripts": {
    "start": "node ./src/index.mjs",
    "build": "node build.mjs",
    "deploy:local": "node ./install.mjs",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage"
  },
  "keywords": [
    "cli",
    "approval",
    "identity",
    "security",
    "openclaw",
    "loginid",
    "agentauth"
  ],
  "author": "LoginID Inc.",
  "license": "Apache-2.0",
  "dependencies": {
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "eventsource": "^4.1.0",
    "http-message-signatures": "^1.0.4",
    "open": "^11.0.0"
  },
  "devDependencies": {
    "esbuild": "^0.27.4",
    "jest": "^30.3.0"
  }
}
